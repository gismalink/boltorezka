{
  "name": "@boltorezka/api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts src/*.test.ts",
    "spike:socketio:server": "tsx src/spikes/socketio-poc/server.ts",
    "spike:socketio:client": "tsx src/spikes/socketio-poc/client.ts",
    "spike:ws:server": "tsx src/spikes/socketio-poc/native-ws-server.ts",
    "spike:ws:client": "tsx src/spikes/socketio-poc/native-ws-client.ts",
    "spike:compare": "tsx src/spikes/socketio-poc/compare.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "livekit-server-sdk": "^2.15.0",
    "pg": "^8.13.3",
    "redis": "^4.7.0",
    "zod": "^3.24.2"
  }
}
