{
  "name": "boltorezka-desktop",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "description": "Electron desktop shell for Boltorezka",
  "author": "Boltorezka Team",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n WEB,DESKTOP -c cyan,green \"npm --prefix ../web run dev -- --host 127.0.0.1 --port 5173\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "electron .",
    "build:renderer": "node ./scripts/build-renderer.cjs",
    "build": "npm run build:renderer && node ./scripts/run-electron-builder.cjs --dir",
    "dist": "npm run build:renderer && node ./scripts/run-electron-builder.cjs",
    "dist:test": "cross-env ELECTRON_UPDATE_CHANNEL=test npm run dist",
    "dist:prod": "cross-env ELECTRON_UPDATE_CHANNEL=prod npm run dist"
  },
  "build": {
    "appId": "art.gismalink.boltorezka.desktop",
    "productName": "Boltorezka",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "src/main.cjs"
    },
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.social-networking",
      "extendInfo": {
        "NSCameraUsageDescription": "Boltorezka uses your camera for voice and video rooms.",
        "NSMicrophoneUsageDescription": "Boltorezka uses your microphone for voice and video rooms."
      }
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.3.9",
    "wait-on": "^8.0.3"
  }
}
