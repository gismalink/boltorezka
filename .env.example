POSTGRES_USER=boltorezka
POSTGRES_PASSWORD=boltorezka_dev_password
POSTGRES_DB=boltorezka
API_PORT=8080
JWT_SECRET=<change-me>
JWT_EXPIRES_IN=12h
CORS_ORIGIN=http://localhost:5173
AUTH_MODE=sso
AUTH_SSO_BASE_URL=http://localhost:3000
AUTH_SSO_REQUEST_TIMEOUT_MS=5000
ALLOWED_RETURN_HOSTS=localhost,test.boltorezka.gismalink.art,boltorezka.gismalink.art
SUPER_ADMIN_EMAIL=gismalink@gmail.com

# Database & Redis
DATABASE_URL=postgres://boltorezka:boltorezka_dev_password@localhost:5432/boltorezka
REDIS_URL=redis://localhost:6379

# Auth session cookies
# AUTH_COOKIE_MODE=0
# AUTH_SESSION_COOKIE_NAME=boltorezka_session
# AUTH_SESSION_COOKIE_SECURE=1
# AUTH_SESSION_COOKIE_SAMESITE=Lax
# AUTH_SESSION_COOKIE_DOMAIN=
# AUTH_SESSION_COOKIE_PATH=/
# AUTH_SESSION_COOKIE_MAX_AGE_SEC=2592000

# LiveKit (voice/video calls)
# LIVEKIT_ENABLED=1
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_TOKEN_TTL_SEC=1800

# Chat uploads
# CHAT_STORAGE_PROVIDER=localfs
# CHAT_UPLOAD_MAX_SIZE_BYTES=5242880
# CHAT_UPLOAD_INIT_TTL_SEC=600
# CHAT_UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp

# MinIO / S3 (when CHAT_STORAGE_PROVIDER=minio)
# CHAT_MINIO_ENDPOINT=
# CHAT_MINIO_REGION=us-east-1
# CHAT_MINIO_ACCESS_KEY=
# CHAT_MINIO_SECRET_KEY=
# CHAT_MINIO_BUCKET=
# CHAT_MINIO_FORCE_PATH_STYLE=1

# Build / deploy metadata
# APP_VERSION=0.1.0
# APP_BUILD_SHA=
# API_SERVE_STATIC=1
# RTC_FEATURE_INITIAL_STATE_REPLAY=1

# WebRTC (web client)
# Optional explicit auth base URL override for SSO redirect links in web UI
# VITE_AUTH_BASE_URL=https://auth.gismalink.art
# Bearer storage mode for web client:
# - memory (default, recommended)
# - localstorage (legacy fallback for controlled environments)
VITE_AUTH_BEARER_STORAGE=memory
# JSON array of RTCIceServer objects, e.g.
# [{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
# Known-good test baseline (2026-03-01):
# VITE_RTC_ICE_TRANSPORT_POLICY=relay
# VITE_RTC_ICE_SERVERS_JSON=[{"urls":["turns:gismalink.art:5349?transport=tcp"],"username":"<turn-username>","credential":"<turn-password>"}]
# Canonical baseline details: docs/runbooks/VOICE_BASELINE_RUNBOOK.md
VITE_RTC_ICE_SERVERS_JSON=
# all | relay
VITE_RTC_ICE_TRANSPORT_POLICY=all
# reconnect backoff policy for active call session
VITE_RTC_RECONNECT_MAX_ATTEMPTS=3
VITE_RTC_RECONNECT_BASE_DELAY_MS=1000
VITE_RTC_RECONNECT_MAX_DELAY_MS=8000

# Web Push (optional)
WEB_PUSH_ENABLED=0
WEB_PUSH_SUBJECT=mailto:ops@example.com
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
