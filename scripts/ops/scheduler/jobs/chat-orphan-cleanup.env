# Every 6 hours: remove orphan chat objects from object storage.
JOB_ID=chat-orphan-cleanup
JOB_ENABLED=1
JOB_SCHEDULE_KIND=interval
JOB_SCHEDULE_VALUE=21600
JOB_WORKDIR=$HOME/srv/datowave
JOB_COMMAND="bash ./scripts/ops/chat-orphan-cleanup.sh"
JOB_LOG_RETENTION_DAYS=14

# Uses test smoke token file generated on server by smoke auth bootstrap flow.
JOB_ENV_CHAT_ORPHAN_BASE_URL=https://test.datowave.com
JOB_ENV_CHAT_ORPHAN_BEARER_TOKEN_FILE=.deploy/smoke-auth-livekit-gate.env
JOB_ENV_CHAT_ORPHAN_BEARER_TOKEN_FILE_KEY=SMOKE_TEST_BEARER_TOKEN
JOB_ENV_CHAT_ORPHAN_PREFIX=chat-attachments/
JOB_ENV_CHAT_ORPHAN_OLDER_THAN_SEC=86400
JOB_ENV_CHAT_ORPHAN_MAX_SCAN=5000
JOB_ENV_CHAT_ORPHAN_MAX_DELETE=500
JOB_ENV_CHAT_ORPHAN_DRY_RUN=0
JOB_ENV_CHAT_ORPHAN_STRICT=1
