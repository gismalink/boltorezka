# Every 28 days: rotate TURN static credentials and write rotation marker for smoke freshness gate.
JOB_ID=turn-credentials-rotate
JOB_ENABLED=1
JOB_SCHEDULE_KIND=interval
JOB_SCHEDULE_VALUE=2419200
JOB_WORKDIR=${DATOWAVE_BASE_DIR:-$HOME/srv/datowave}
JOB_COMMAND="bash ./scripts/ops/rotate-turn-credentials.sh"
JOB_LOG_RETENTION_DAYS=30
JOB_ENV_TURN_ROTATE_APPLY=1
JOB_ENV_TURN_ROTATE_UPDATE_ICE_JSON=1
JOB_ENV_TURN_ROTATE_ENV_FILE=infra/.env.host
JOB_ENV_TURN_ROTATE_META_FILE=.deploy/turn-credentials-last-rotation.env
JOB_ENV_TURN_ROTATE_HISTORY_FILE=.deploy/turn-credentials-rotation.log
