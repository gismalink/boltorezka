# Nightly backup of test+prod PostgreSQL clusters.
JOB_ID=backup-postgres-all
JOB_ENABLED=1
JOB_SCHEDULE_KIND=interval
JOB_SCHEDULE_VALUE=86400
JOB_WORKDIR=$HOME/srv/edge
JOB_COMMAND="STRICT_MODE=1 BACKUP_ROOT=/Volumes/datas3/srv/backups/server-databases bash ./scripts/backup-all-server-dbs.sh"
JOB_LOG_RETENTION_DAYS=21
