JOB_ID=slo-rolling-gate
JOB_ENABLED=1
JOB_SCHEDULE_KIND=interval
JOB_SCHEDULE_VALUE=300
JOB_WORKDIR=${BOLTOREZKA_BASE_DIR:-$HOME/srv/boltorezka}
JOB_COMMAND="bash ./scripts/ops/slo-rolling-gate.sh"
JOB_TIMEOUT_SECONDS=0
JOB_LOG_RETENTION_DAYS=14

# Keep secrets out of git. Set SLO_BEARER_TOKEN locally on server copy if needed.
JOB_ENV_SLO_BASE_URL=https://test.datowave.com
JOB_ENV_SLO_BEARER_TOKEN_FILE=.deploy/smoke-auth-livekit-gate.env
JOB_ENV_SLO_BEARER_TOKEN_FILE_KEY=SMOKE_TEST_BEARER_TOKEN
JOB_ENV_SLO_STRICT=0
JOB_ENV_SLO_RETENTION_MINUTES=1440
JOB_ENV_SLO_MIN_ACK_5M=20
JOB_ENV_SLO_MIN_ACK_30M=80
JOB_ENV_SLO_NACK_RATE_5M=0.12
JOB_ENV_SLO_NACK_RATE_30M=0.08
JOB_ENV_SLO_RECONNECT_SPIKE_30M=60
JOB_ENV_SLO_INITIAL_STATE_LAG_AVG_MS_30M=15000
