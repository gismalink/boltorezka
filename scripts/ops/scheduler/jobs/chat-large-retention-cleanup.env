# Daily dry-run in test: evaluate large-file retention cleanup candidates.
JOB_ID=chat-large-retention-cleanup
JOB_ENABLED=1
JOB_SCHEDULE_KIND=interval
JOB_SCHEDULE_VALUE=86400
JOB_WORKDIR=${DATOWAVE_BASE_DIR:-$HOME/srv/datowave}
JOB_COMMAND="bash ./scripts/ops/chat-large-retention-cleanup.sh"
JOB_LOG_RETENTION_DAYS=14

# Uses test smoke token file generated on server by smoke auth bootstrap flow.
JOB_ENV_CHAT_LARGE_RETENTION_BASE_URL=https://test.datowave.com
JOB_ENV_CHAT_LARGE_RETENTION_BEARER_TOKEN_FILE=.deploy/smoke-auth-livekit-gate.env
JOB_ENV_CHAT_LARGE_RETENTION_BEARER_TOKEN_FILE_KEY=SMOKE_TEST_BEARER_TOKEN

# Start with dry-run in test; switch to 0 after validation.
JOB_ENV_CHAT_LARGE_RETENTION_DRY_RUN=1
JOB_ENV_CHAT_LARGE_RETENTION_THRESHOLD_BYTES=26214400
JOB_ENV_CHAT_LARGE_RETENTION_DAYS=7
JOB_ENV_CHAT_LARGE_RETENTION_MAX_DELETE=200
JOB_ENV_CHAT_LARGE_RETENTION_STRICT=1
