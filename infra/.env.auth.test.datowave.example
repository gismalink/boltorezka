PORT=3000
NODE_ENV=production

# DB / session / jwt (isolated datowave test auth in boltorezka stack)
DATABASE_URL=postgresql://auth_test_datowave:auth_test_datowave@boltorezka-auth-db-test-datowave:5432/auth_test_datowave
MYSECTER=<set-test-datowave-jwt-secret>
SESSION_SECRET=<set-test-datowave-session-secret>
TOKEN_COOKIE_DOMAIN=.datowave.com

# OAuth (test datowave)
GOOGLE_CLIENT_ID=<set-google-client-id-for-test-auth-datowave>
GOOGLE_CLIENT_SECRET=<set-google-client-secret-for-test-auth-datowave>
YANDEX_CLIENT_ID=<set-yandex-client-id-for-test-auth-datowave>
YANDEX_CLIENT_SECRET=<set-yandex-client-secret-for-test-auth-datowave>

# Hostnames
AUTH_PUBLIC_BASE_URL=https://test.auth.datowave.com
ALLOWED_RETURN_HOSTS=test.datowave.com
AUTH_CORS_ORIGINS=https://test.datowave.com
