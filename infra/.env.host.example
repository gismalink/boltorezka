# -------------------------------
# Boltorezka host compose settings
# Copy to: infra/.env.host
# -------------------------------

# ===== TURN (shared for test/prod) =====
TURN_REALM=gismalink.art
TURN_CERT_DOMAIN=gismalink.art
TURN_EXTERNAL_IP=<set-public-server-ip>
# Optional explicit local bind for coturn (use host LAN/VPN IP when needed)
# TURN_LISTEN_IP=<set-host-local-ip>
# Optional explicit relay address advertised by coturn
# TURN_RELAY_IP=<set-host-local-ip-or-public-ip>
TURN_USERNAME=<set-turn-username>
TURN_PASSWORD=<set-turn-password>
# 1 = enable verbose TURN logs, 0 = quieter logs
TURN_VERBOSE=1
# On Docker Desktop (macOS), avoid ephemeral 49152-65535 to prevent UDP bind conflicts.
# Keep relay range compact and forward the same UDP range on the router/NAT.
TURN_MIN_PORT=30000
TURN_MAX_PORT=31000

# ===== TEST =====
TEST_POSTGRES_DB=boltorezka_test
TEST_POSTGRES_USER=boltorezka_test
TEST_POSTGRES_PASSWORD=<set-strong-test-password>

TEST_JWT_SECRET=<set-strong-test-jwt-secret>
TEST_JWT_EXPIRES_IN=7d
TEST_CORS_ORIGIN=https://test.boltorezka.gismalink.art
TEST_AUTH_SSO_BASE_URL=https://test.auth.gismalink.art
TEST_ALLOWED_RETURN_HOSTS=test.boltorezka.gismalink.art
TEST_SUPER_ADMIN_EMAIL=gismalink@gmail.com
TEST_WS_CALL_DEBUG=0
TEST_HEALTHCHECK_URL=https://test.boltorezka.gismalink.art/health
TEST_VITE_RTC_ICE_SERVERS_JSON=
TEST_VITE_RTC_ICE_TRANSPORT_POLICY=all
TEST_VITE_RTC_RECONNECT_MAX_ATTEMPTS=3
TEST_VITE_RTC_RECONNECT_BASE_DELAY_MS=1000
TEST_VITE_RTC_RECONNECT_MAX_DELAY_MS=8000
TEST_API_SERVE_STATIC=0
# Stage A LiveKit foundation (service profile `livekit-test`).
# Keep disabled for default deploy path; enable explicitly in runbook steps.
TEST_LIVEKIT_SIGNAL_PORT=7880
TEST_LIVEKIT_TCP_PORT=7881
TEST_LIVEKIT_RTC_PORT_START=34000
TEST_LIVEKIT_RTC_PORT_END=34999
LIVEKIT_TEST_API_KEY=<set-livekit-test-api-key>
LIVEKIT_TEST_API_SECRET=<set-livekit-test-api-secret>
TEST_LIVEKIT_ENABLED=1
TEST_LIVEKIT_URL=wss://test.boltorezka.gismalink.art/livekit
TEST_LIVEKIT_TOKEN_TTL_SEC=1800
# Example:
# TEST_VITE_RTC_ICE_SERVERS_JSON='[{"urls":["turn:gismalink.art:3478?transport=udp","turn:gismalink.art:3478?transport=tcp","turns:gismalink.art:5349?transport=tcp"],"username":"<set-turn-username>","credential":"<set-turn-password>"}]'

# ===== PROD =====
PROD_POSTGRES_DB=boltorezka_prod
PROD_POSTGRES_USER=boltorezka_prod
PROD_POSTGRES_PASSWORD=<set-strong-prod-password>

PROD_JWT_SECRET=<set-strong-prod-jwt-secret>
PROD_JWT_EXPIRES_IN=7d
PROD_CORS_ORIGIN=https://boltorezka.gismalink.art
PROD_AUTH_SSO_BASE_URL=https://auth.gismalink.art
PROD_ALLOWED_RETURN_HOSTS=boltorezka.gismalink.art
PROD_SUPER_ADMIN_EMAIL=gismalink@gmail.com
PROD_WS_CALL_DEBUG=0
PROD_HEALTHCHECK_URL=https://boltorezka.gismalink.art/health
PROD_VITE_RTC_ICE_SERVERS_JSON=
PROD_VITE_RTC_ICE_TRANSPORT_POLICY=all
PROD_VITE_RTC_RECONNECT_MAX_ATTEMPTS=3
PROD_VITE_RTC_RECONNECT_BASE_DELAY_MS=1000
PROD_VITE_RTC_RECONNECT_MAX_DELAY_MS=8000
PROD_API_SERVE_STATIC=0
PROD_LIVEKIT_SIGNAL_PORT=7880
PROD_LIVEKIT_TCP_PORT=7882
PROD_LIVEKIT_RTC_PORT_START=35000
PROD_LIVEKIT_RTC_PORT_END=35999
PROD_LIVEKIT_ENABLED=1
PROD_LIVEKIT_URL=wss://boltorezka.gismalink.art/livekit
PROD_LIVEKIT_API_KEY=<set-livekit-prod-api-key>
PROD_LIVEKIT_API_SECRET=<set-livekit-prod-api-secret>
PROD_LIVEKIT_TOKEN_TTL_SEC=1800
# Example:
# PROD_VITE_RTC_ICE_SERVERS_JSON='[{"urls":["turn:gismalink.art:3478?transport=udp","turn:gismalink.art:3478?transport=tcp","turns:gismalink.art:5349?transport=tcp"],"username":"<set-turn-username>","credential":"<set-turn-password>"}]'
