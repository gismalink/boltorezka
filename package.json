{
  "name": "boltorezka",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "check": "npm run check:quick",
    "check:quick": "bash ./scripts/verify-all.sh",
    "check:required": "bash ./scripts/verify-required.sh",
    "check:api-types": "npm --prefix apps/api run typecheck",
    "web:install": "npm --prefix apps/web install",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "desktop:install": "npm --prefix apps/desktop-electron install",
    "desktop:dev": "npm --prefix apps/desktop-electron run dev",
    "desktop:build": "npm --prefix apps/desktop-electron run build",
    "desktop:smoke": "bash ./scripts/smoke/smoke-desktop-foundation.sh \"${REPO_DIR:-$PWD}\"",
    "desktop:smoke:full": "npm run desktop:smoke && npm run smoke:desktop:runtime",
    "desktop:smoke:m2": "npm run desktop:smoke:full && npm run smoke:desktop:reconnect && npm run smoke:desktop:telemetry",
    "desktop:smoke:m2:soak": "npm run desktop:smoke:m2 && npm run smoke:desktop:soak",
    "desktop:smoke:m2:secure": "npm run desktop:smoke:m2:soak && npm run smoke:desktop:security",
    "desktop:smoke:m2:secure:diag": "npm run desktop:smoke:m2:secure && npm run smoke:desktop:diagnostics",
    "desktop:smoke:m2:sleepwake": "npm run desktop:smoke:m2:secure:diag && npm run smoke:desktop:sleep-wake",
    "desktop:smoke:m2:stability": "npm run desktop:smoke:m2:sleepwake && npm run smoke:desktop:stability",
    "smoke:desktop:runtime": "node ./scripts/smoke/smoke-desktop-runtime.mjs",
    "smoke:desktop:reconnect": "node ./scripts/smoke/smoke-desktop-reconnect.mjs",
