    "deploy:test": "bash ./scripts/deploy/deploy-test-from-ref.sh \"${TEST_REF:?set TEST_REF=origin/feature/<name>}\" \"${REPO_DIR:-$PWD}\"",
    "deploy:test:smoke": "bash ./scripts/deploy/deploy-test-and-smoke.sh \"${TEST_REF:?set TEST_REF=origin/feature/<name>}\" \"${REPO_DIR:-$PWD}\"",
    "deploy:desktop:server": "bash ./scripts/deploy/build-desktop-server-and-publish.sh \"${DESKTOP_REF:?set DESKTOP_REF=origin/feature/<name>}\" \"${REPO_DIR:-$PWD}\"",
