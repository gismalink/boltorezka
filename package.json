    "smoke:desktop:media-controls": "node ./scripts/smoke/smoke-desktop-media-controls.mjs",
    "smoke:desktop:screenshare": "node ./scripts/smoke/smoke-desktop-screenshare.mjs",
    "smoke:desktop:update-feed": "node ./scripts/smoke/smoke-desktop-update-feed.mjs",
    "smoke:api": "node ./scripts/smoke/smoke-api.mjs",
    "smoke:auth:session": "node ./scripts/smoke/smoke-auth-session.mjs",
