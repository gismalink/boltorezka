    "deploy:test:livekit:allrooms": "bash ./scripts/deploy/deploy-test-livekit-all-default.sh",
    "deploy:prod": "bash ./scripts/deploy/deploy-prod-from-ref.sh \"${PROD_REF:-origin/main}\" \"${REPO_DIR:-$PWD}\""
